{
  "manifest_version": 2,
  "name": "Puppeteer",
  "version": "1.0",
  "description": "AI personas that browse to obfuscate behavior",
  "permissions": ["tabs", "storage", "scripting", "activeTab", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Puppeteer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
