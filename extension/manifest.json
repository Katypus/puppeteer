{
  "manifest_version": 2,
  "name": "Puppeteer",
  "version": "1.6",
  "description": "Cut your strings and spin new ones.",
  "browser_specific_settings": {
    "gecko": {
      "id": "puppeteer@example.com",
      "data_collection_permissions": {
        "required": ["websiteContent"],
        "optional": []
      }
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "nativeMessaging",
    "<all_urls>",
    "https://www.google.com/*",
    "https://www.bing.com/*",
    "https://duckduckgo.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Puppeteer",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "sprite/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*",
        "https://www.bing.com/*",
        "https://duckduckgo.com/*",
        "<all_urls>"
      ],
      "js": ["helpers.js", "executor.js", "sensor.js", "main.js"],
      "run_at": "document_idle"
    }
  ]
}
